## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
build/
bld/
[Bb]in/
[Oo]bj/

# Visual Studio cache/options directory
.vs/
.vscode/

# Database files
*.db
*.db-shm
*.db-wal

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Auto generated files
*.dbmdl
*.jfm
*.pfx
*.publishsettings

# ReSharper
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# NuGet Packages
*.nupkg
**/packages/*
!**/packages/build/

# Visual Studio cache files
project.lock.json
project.fragment.lock.json
artifacts/

# Others
.DS_Store
Thumbs.db
*.stackdump

# Logs
*.log
logs/

# Test / coverage outputs
TestResults/
coverage/
coverage.*
*.coverage
*.coveragexml

# JetBrains Rider
.idea/
*.sln.iml

# Dotnet temp
*.tmp
*.temp
*.cache

# Environment / local secrets
.env
.env.*
/appsettings.json
appsettings.Local.json
**/appsettings.Local.json

# Runtime uploaded files
server-q-it/images/
server-q-it/materials/
